{
  "taskGroups": [
    {
      "taskCount": 115, 
      "parallelism": 50,
      "taskSpec": {
        "runnables": [
          {
            "displayName": "Prepare Local SSD and Data",
            "script": {
              "text": "mkfs.ext4 -F /dev/nvme0n1 && mkdir -p /mnt/disks/ssd && mount /dev/nvme0n1 /mnt/disks/ssd && chmod a+w /mnt/disks/ssd && gsutil -m cp gs://needle-files/kegg-downloads/ko.hmm.* /mnt/disks/ssd/ && gsutil cp gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/proteins_${BATCH_TASK_INDEX}.fasta /mnt/disks/ssd/input.fasta"
            }
          },
          {
            "displayName": "Run Needle Core HMMScan",
            "container": {
              "imageUri": "us-east1-docker.pkg.dev/needle-489321/needle-docker/needle-core:latest",
              "commands": [
                "python3", "scripts/classify/classify.py",
                "--disable-cutoff-ga",
                "--cpu", "4",
                "--genome-accession", "_",
                "--fasta-file", "/mnt/disks/ssd/input.fasta",
                "/mnt/disks/ssd/kegg_db",
                "_",
                "/mnt/disks/ssd/sequence_ko_${BATCH_TASK_INDEX}.tsv"
              ],
              "volumes": [
                "/mnt/disks/ssd:/mnt/disks/ssd"
              ]
            }
          },
          {
            "displayName": "Upload Results",
            "script": {
              "text": "gsutil cp /mnt/disks/ssd/sequence_ko_${BATCH_TASK_INDEX}.tsv gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/"
            }
          }
        ],
        "volumes": [
          {
            "device_name": "google-local-nvme-ssd-0",
            "mount_path": "/mnt/disks/ssd"
          }
        ]
      }
    }
  ],
  "allocationPolicy": {
    "instances": [
      {
        "installGpuDrivers": false,
        "policy": {
          "machineType": "c3-standard-4-lssd",
          "provisioningModel": "SPOT"
        }
      }
    ],
    "location": {
      "allowedLocations": [
        "regions/us-east1"
      ]
    }
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}
