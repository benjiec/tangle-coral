{
  "taskGroups": [
    {
      "taskCount": 1, 
      "parallelism": 50,
      "taskSpec": {
        "runnables": [
          {
            "displayName": "Prepare Local SSD and Data",
            "script": {
              "text": "gsutil cp gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/gc-prepare-ssd.sh ./prepare.sh && chmod +x ./prepare.sh && ./prepare.sh"
            }
          },
          {
            "displayName": "Run Needle Core HMMScan",
            "container": {
              "imageUri": "us-east1-docker.pkg.dev/needle-489321/needle-docker/needle-core:latest",
              "commands": [
                "python3", "scripts/classify/classify.py",
                "--disable-cutoff-ga",
                "--cpu", "4",
                "--genome-accession", "_",
                "--fasta-file", "/mnt/disks/ssd/input.faa",
                "--hmm-threshold-file", "/mnt/disks/ssd/ko_thresholds.tsv",
                "/mnt/disks/ssd/ko.hmm",
                "_",
                "/mnt/disks/ssd/sequence_ko_${BATCH_TASK_INDEX}.tsv"
              ],
              "volumes": [
                "/mnt/disks/ssd:/mnt/disks/ssd"
              ]
            }
          },
          {
            "displayName": "Upload Results",
            "script": {
              "text": "ls -l /mnt/disks/ssd/ && gsutil cp /mnt/disks/ssd/sequence_ko_${BATCH_TASK_INDEX}.tsv gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/"
            }
          }
        ]
      }
    }
  ],
  "allocationPolicy": {
    "instances": [
      {
        "installGpuDrivers": false,
        "policy": {
          "machineType": "c3-standard-4-lssd",
          "provisioningModel": "SPOT"
        }
      }
    ],
    "location": {
      "allowedLocations": [
        "regions/us-east1"
      ]
    }
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}
