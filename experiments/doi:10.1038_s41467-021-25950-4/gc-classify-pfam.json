{
  "taskGroups": [
    {
      "taskCount": 400,
      "parallelism": 30,
      "taskSpec": {
        "computeResource": {
          "cpuMilli": 4000,
          "memoryMib": 16000
        },
        "maxRetryCount": 5,
        "runnables": [
          {
            "displayName": "Prepare Local SSD and Data",
            "script": {
              "text": "gsutil cp gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/gc-prepare-ssd-pfam.sh ./prepare-ssd.sh && ./prepare-ssd.sh"
            }
          },
          {
            "displayName": "Download Task Specific Assets",
            "script": {
              "text": "gsutil cp gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/gc-prepare-task-pfam.sh ./prepare_task_${BATCH_TASK_INDEX}.sh && bash ./prepare_task_${BATCH_TASK_INDEX}.sh"
            }
          },
          {
            "displayName": "Run Needle Core HMMScan",
            "container": {
              "imageUri": "us-east1-docker.pkg.dev/needle-489321/needle-docker/needle-core:latest",
              "commands": [
                "/bin/bash",
                "-c",
                "python3 scripts/classify/classify.py --cpu 2 --genome-accession _ --fasta-file /mnt/disks/ssd/input_${BATCH_TASK_INDEX}.faa /mnt/disks/ssd/Pfam-A.hmm _ /mnt/disks/ssd/sequence_pfam_${BATCH_TASK_INDEX}.tsv"
              ],
              "volumes": [
                "/mnt/disks/ssd:/mnt/disks/ssd"
              ]
            }
          },
          {
            "displayName": "Upload Results",
            "script": {
              "text": "ls -l /mnt/disks/ssd/ && gsutil cp /mnt/disks/ssd/sequence_pfam_${BATCH_TASK_INDEX}.tsv gs://needle-files/experiments/doi:10.1038_s41467-021-25950-4/"
            }
          }
        ]
      }
    }
  ],
  "allocationPolicy": {
    "network": {
      "networkInterfaces": [
        {
          "network": "projects/needle-489321/global/networks/default",
          "subnetwork": "projects/needle-489321/regions/us-east1/subnetworks/default",
          "noExternalIpAddress": true
        }
      ]
    },
    "instances": [
      {
        "installGpuDrivers": false,
        "policy": {
          "machineType": "c3-standard-4-lssd",
          "provisioningModel": "SPOT"
        }
      }
    ],
    "location": {
      "allowedLocations": [
        "regions/us-east1"
      ]
    }
  },
  "logsPolicy": {
    "destination": "CLOUD_LOGGING"
  }
}
