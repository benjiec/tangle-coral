      <column caption='Peptide Cohort Timepoint Laplace Corrected Mean' datatype='real' name='[Calculation_3340558442504192]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [peptide],[cohort],[timepoint]:&#10;&#10;(1 + SUM([count])) / (1 + COUNT([sample]))&#10;&#10;}' />
      </column>
      <column caption='Susceptible / Resilient Log2FC by Timepoint' datatype='real' name='[Calculation_3340558445318148]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [peptide],[timepoint]:&#10;&#10;LOG(&#10;  MAX(IF [cohort] == &quot;susceptible&quot; THEN [Calculation_3340558442504192] ELSE NULL END)&#10;    /&#10;  MAX(IF [cohort] == &quot;resilient&quot; THEN [Calculation_3340558442504192] ELSE NULL END)&#10;,2)&#10;}' />
      </column>
      <column caption='HMM Match Log Evalue' datatype='real' name='[Calculation_3340558452473864]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='Log(MAX([dom_evalue],1E-300),10)' />
      </column>
      <column caption='Go Id' datatype='string' name='[GO ID]' role='dimension' type='nominal' />
      <column datatype='string' name='[Module Name]' role='dimension' type='nominal' />
      <column caption='Peptide Cohort Timepoint Stdev' datatype='real' name='[Peptide Cohort Timepoint Laplace Corrected Mean (copy)_3340558444298243]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [peptide],[cohort],[timepoint]: STDEV([count])}' />
      </column>
      <column caption='Susceptible / Resilient SSMD by Timepoint' datatype='real' name='[Susceptible / Resilient Log2FC by Timepoint (copy)_3340558446301189]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [peptide],[timepoint]:&#10;&#10;  (MAX(IF [cohort] == &quot;susceptible&quot; THEN [Calculation_3340558442504192] ELSE NULL END)&#10;    -&#10;   MAX(IF [cohort] == &quot;resilient&quot; THEN [Calculation_3340558442504192] ELSE NULL END))&#10;&#10;    /&#10;&#10;  SQRT(&#10;    POWER(MAX(IF [cohort] == &quot;susceptible&quot; THEN [Peptide Cohort Timepoint Laplace Corrected Mean (copy)_3340558444298243] ELSE NULL END),2)+&#10;    POWER(MAX(IF [cohort] == &quot;resilient&quot; THEN [Peptide Cohort Timepoint Laplace Corrected Mean (copy)_3340558444298243] ELSE NULL END),2)&#10;  )&#10;&#10;}' />
      </column>
      <column caption='t2 / t1  Log2FC by Cohort' datatype='real' name='[Susceptible / Resilient Log2FC by Timepoint (copy)_3340558447726598]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [peptide],[cohort]:&#10;&#10;LOG(&#10;  MAX(IF [timepoint] == &quot;t2&quot; THEN [Calculation_3340558442504192] ELSE NULL END)&#10;    /&#10;  MAX(IF [timepoint] == &quot;t1&quot; THEN [Calculation_3340558442504192] ELSE NULL END)&#10;,2)&#10;}' />
      </column>
