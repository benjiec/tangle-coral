      <aliases enabled='yes' />
      <column caption='E-value Rank' datatype='integer' name='[Calculation_2248294184968193]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [custom_metric_name] == &quot;evalue-rank&quot; THEN INT([custom_metric_value]) ELSE NULL END' />
      </column>
      <column caption='Match Is Assigned' datatype='boolean' name='[Calculation_2248294185197570]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[bitscore] &gt;= [bitscore_threshold] AND [Calculation_2248294184968193] &lt;= 10' />
      </column>
      <column caption='Target Length' datatype='integer' name='[Calculation_2248294199050249]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([target_start]-[target_end])+1' />
      </column>
      <column caption='Match is Putative or Assigned' datatype='boolean' name='[Calculation_2248294200328204]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Match Is Assigned (copy)_2248294199975947] OR [Calculation_2248294185197570]' />
      </column>
      <column caption='Assignment Status' datatype='string' name='[Calculation_2248294200533005]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [Calculation_2248294185197570] THEN &quot;Assigned&quot;&#10;ELSEIF [Match Is Assigned (copy)_2248294199975947] THEN &quot;Putative&quot;&#10;ELSE NULL END' />
      </column>
      <column caption='Assigned KO' datatype='string' name='[Calculation_2248294208561170]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [query_accession], [query_database]: MAX(&#10;&#10;IF [Calculation_2248294185197570] AND&#10;   [target_database] == &quot;KO&quot; AND&#10;   [Calculation_2248294184968193] ==&#10;&#10;// Min assigned Evalue&#10;{FIXED [query_accession], [query_database]:&#10;MIN(IF [Calculation_2248294185197570] THEN [Calculation_2248294184968193] ELSE 100 END)&#10;}&#10;&#10;THEN [target_accession]&#10;ELSE NULL&#10;END&#10;&#10;)}' />
      </column>
      <column caption='Pfam Family ID or NULL' datatype='string' name='[Calculation_2248294212476949]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF [target_database] == &quot;Pfam-A&quot; THEN [target_accession] ELSE NULL END' />
      </column>
      <column caption='Has Multiple Sequence Source' datatype='boolean' name='[Calculation_2248294214234137]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [Genome Accession]:&#10;IF COUNTD([sequence_source]) &gt; 1 THEN TRUE ELSE FALSE END&#10;}' />
      </column>
      <column datatype='string' name='[Genus]' role='dimension' type='nominal' />
      <column datatype='string' name='[Kingdom]' role='dimension' type='nominal' />
      <column caption='Match Is Putative' datatype='boolean' name='[Match Is Assigned (copy)_2248294199975947]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[bitscore] &lt; [bitscore_threshold] AND&#10;[bitscore] &gt;= 0.9*[bitscore_threshold] AND&#10;[Calculation_2248294184968193] &lt;= 10' />
      </column>
      <column datatype='string' name='[Organism]' role='dimension' type='nominal' />
      <column datatype='string' name='[Phylum]' role='dimension' type='nominal' />
      <column caption='Query Length' datatype='integer' name='[Target Length (copy)_2248294199173130]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([query_start]-[query_end])+1' />
      </column>
