      <column caption='Count of Measured Sequences Mapped to Pfam' datatype='integer' name='[Calculation_0736715795451907]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Pfam ID]: COUNTD([sequence_id (des2_tall.tsv)])}' />
      </column>
      <column caption='Count of KO Mapped Measured Sequences by Pfam' datatype='integer' name='[Calculation_0736715796127748]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [Pfam ID]: COUNTD(IF NOT ISNULL([Ortholog ID]) THEN [sequence_id (des2_tall.tsv)] ELSE NULL END)}' />
      </column>
      <column caption='GO term' datatype='string' name='[Calculation_1027600580857860]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IFNULL([GO description (pfam_go_simple.tsv1)], NULL)' />
      </column>
      <column caption='Has Counts' datatype='boolean' name='[Calculation_1027600583294986]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [sequence_id]: MAX([count]) &gt; 0}' />
      </column>
      <column caption='Has KO Mapping' datatype='boolean' name='[Calculation_2083337837871104]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [sequence_id]: NOT ISNULL(MIN([Ortholog ID]))}' />
      </column>
      <column caption='ABS(L2FC)' datatype='real' name='[Calculation_4157360317693952]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([log2FoldChange])' />
      </column>
      <column caption='negLog10Padj' datatype='real' name='[Calculation_6080198875439106]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-LOG([padj],10)' />
      </column>
