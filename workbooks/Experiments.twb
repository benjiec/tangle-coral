      <column caption='Target Accession no version' datatype='string' name='[Calculation_0424687539331073]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='IF LEFT([target_accession], 2) == &quot;PF&quot;&#10;THEN LEFT([target_accession], 7)&#10;ELSE [target_accession]&#10;END' />
      </column>
      <column caption='Secondary Ortholog Name' datatype='string' name='[Calculation_0424687670321159]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [target_accession (experiment_detected1)]: MAX([ortholog_name (kegg_orthologs1)])}' />
      </column>
      <column caption='Has KO Match' datatype='boolean' name='[Calculation_2141644358578178]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [sequence_accession], [sequence_database]: COUNTD([ortholog_id (kegg_orthologs)]) &gt; 0}' />
      </column>
      <column caption='-log(Padj)' datatype='real' name='[Calculation_3343751797477378]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='-Log([padj],10)' />
      </column>
      <column caption='Rank' datatype='real' name='[Calculation_3343751802658819]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='(ABS([log2FoldChange]) * [Calculation_3343751797477378]) / (1 + [max_cv])' />
      </column>
      <column caption='Has Pfam Match' datatype='boolean' name='[Has KO Match (copy)_2141644358918147]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [sequence_accession], [sequence_database]: COUNTD([pfam_accession (pfam_domains)]) &gt; 0}' />
