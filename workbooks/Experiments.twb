  <worksheets>
    <worksheet name='Analysis Gene Rankings'>
      <table>
        <view>
          <datasources>
            <datasource caption='experiment_transcripts+ (tangle_coral)' name='federated.08gaxrk1nsfbe01g8hwki06thas5' />
          </datasources>
          <datasource-dependencies datasource='federated.08gaxrk1nsfbe01g8hwki06thas5'>
            <column caption='RIGHT([Gene Id (Experiment DeSeq2 Gene)],18)' datatype='string' name='[Calculation_3146327463985158]' role='dimension' type='nominal' user:unnamed='Analysis Gene Rankings'>
              <calculation class='tableau' formula='RIGHT([sequence_id],18)' />
            </column>
            <column caption='-log(Padj)' datatype='real' name='[Calculation_3489442696458245]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='-Log([padj],10)' />
            </column>
            <column caption='Rank' datatype='integer' name='[Calculation_3580496025751556]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(ABS([log2FoldChange])*[Calculation_3489442696458245] / (1 + [max_cv]))' />
            </column>
            <column caption='COUNTD([Ortholog Id]) &gt; 0' datatype='boolean' name='[Calculation_4508003091501061]' role='measure' type='nominal' user:unnamed='Analysis Gene Rankings'>
              <calculation class='tableau' formula='COUNTD([ortholog_id]) &gt; 0' />
            </column>
            <column caption='COUNTD([Pfam Accession]) &gt; 0' datatype='boolean' name='[Calculation_4508003091591175]' role='measure' type='nominal' user:unnamed='Analysis Gene Rankings'>
              <calculation class='tableau' formula='COUNTD([pfam_accession]) &gt; 0' />
            </column>
            <column caption='COUNTD([Uniprot Accession]) &gt; 0' datatype='boolean' name='[Calculation_4508003091652617]' role='measure' type='nominal' user:unnamed='Analysis Gene Rankings'>
              <calculation class='tableau' formula='COUNTD([uniprot_accession]) &gt; 0' />
