      <column caption='Secondary Ortholog Name' datatype='string' name='[Calculation_0424687670321159]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [target_accession (experiment_detected1)]: MAX([ortholog_name (kegg_orthologs1)])}' />
