          <datasource-dependencies datasource='federated.08gaxrk1nsfbe01g8hwki06thas5'>
            <column caption='Transcript Contributes to Gene Metrics' datatype='boolean' name='[Calculation_3259989521653762]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='// Same direction&#10;&#10;[log2FoldChange (experiment_deseq2_tall1)] * [log2FoldChange] &gt; 0&#10;&#10;AND&#10;&#10;// Also significant&#10;&#10;ABS([log2FoldChange (experiment_deseq2_tall1)]) &gt; 0.33 * ABS([log2FoldChange])&#10;&#10;AND&#10;&#10;// Has fair share of reads&#10;&#10;[baseMean (experiment_deseq2_tall1)] &gt; 0.33 *&#10;&#10;[Calculation_3259989522898947] /&#10;[Sum of Transcript Base Mean in Gene (copy)_3259989524221956]' />
            </column>
            <column caption='Sum of Transcript Base Mean in Gene' datatype='real' name='[Calculation_3259989522898947]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='{FIXED [experiment_id],[analysis_type],[analysis_type (experiment_deseq2_tall1)],[sequence_id]: SUM([baseMean (experiment_deseq2_tall1)])}' />
            </column>
            <column caption='-log(Padj)' datatype='real' name='[Calculation_3489442696458245]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='-Log([padj],10)' />
            </column>
            <column caption='Rank' datatype='integer' name='[Calculation_3580496025751556]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='INT(ABS([log2FoldChange])*[Calculation_3489442696458245] / (1 + [max_cv]))' />
            </column>
            <column caption='Protein Length' datatype='integer' name='[Calculation_3580496036597765]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='ABS([target_end (experiment_transcript_proteins1)]-[target_start (experiment_transcript_proteins1)])+1' />
            </column>
            <column aggregation='Sum' caption='Match Length on Protein' datatype='integer' name='[Calculation_3580496037228550]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='ABS([query_end (experiment_detected)]-[query_start (experiment_detected)])+1' />
            </column>
            <column caption='Match % of Protein' datatype='real' name='[Calculation_3580496037695496]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='100 * [Calculation_3580496037228550] / [Calculation_3580496036597765]' />
            </column>
            <column caption='Protein Start on Transcript' datatype='integer' name='[Calculation_3580496038526986]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='IF [query_start] &lt; [query_end]&#10;THEN&#10;  [query_start (experiment_transcript_proteins1)]+([target_start]-[query_start])&#10;ELSE&#10;  [query_end (experiment_transcript_proteins1)]+([target_start]-[query_end])&#10;END' />
            </column>
            <column caption='Effective / Physical Length' datatype='real' name='[Calculation_3580496110145548]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='[effective_length] / [weighted_physical_length]' />
            </column>
            <column caption='Protein Length on Transcript' datatype='integer' name='[Calculation_3580496112594957]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='ABS([Calculation_3580496038526986]-[Protein Start on Transcript (copy)_3580496038637579])+1' />
            </column>
            <column caption='Protein % of Transcript' datatype='real' name='[Calculation_3580496112713742]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='100 * [Calculation_3580496112594957] / INT([sequence_length])' />
            </column>
            <column caption='Protein End on Transcript' datatype='integer' name='[Protein Start on Transcript (copy)_3580496038637579]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='IF [query_start] &lt; [query_end]&#10;THEN&#10;  [query_end (experiment_transcript_proteins1)]+([target_start]-[query_start])&#10;ELSE&#10;  [query_start (experiment_transcript_proteins1)]+([target_start]-[query_end])&#10;END' />
            </column>
            <column caption='Num of Comparable Transcripts in Gene' datatype='integer' name='[Sum of Transcript Base Mean in Gene (copy)_3259989524221956]' role='measure' type='ordinal'>
              <calculation class='tableau' formula='{FIXED [experiment_id],&#10;       [analysis_type],&#10;       [analysis_type (experiment_deseq2_tall1)],&#10;       [sequence_id]:&#10;&#10;COUNTD([sequence_id (experiment_deseq2_tall1)])&#10;&#10;}' />
            </column>
            <column caption='Analysis Type (Transcript)' datatype='string' name='[analysis_type (experiment_deseq2_tall1)]' role='dimension' type='nominal' />
            <column caption='Analysis Type (Gene)' datatype='string' name='[analysis_type]' role='dimension' type='nominal' />
