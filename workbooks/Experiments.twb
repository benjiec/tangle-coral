    <worksheet name='Transcript Cluster Differential Expression Patterns'>
      <table>
        <view>
          <datasources>
            <datasource caption='experiment_transcripts+ (tangle_coral)' name='federated.08gaxrk1nsfbe01g8hwki06thas5' />
          </datasources>
          <datasource-dependencies datasource='federated.08gaxrk1nsfbe01g8hwki06thas5'>
            <column aggregation='Sum' caption='Cluster Size' datatype='integer' name='[Calculation_0580962811068418]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{FIXED [cluster_name]: COUNTD([member_accession])}' />
            </column>
            <column caption='Cluster Gene Over' datatype='integer' name='[Calculation_2106604513918979]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [cluster_name],[member_database],[gene_id]: IF AVG([log2FoldChange]) &gt; 0 AND MIN([Calculation_3489442696458245]) &gt;= 1.3 THEN 1 ELSE 0 END}' />
            </column>
            <column caption='Cluster Transcriptional Homogeneity Score' datatype='real' name='[Calculation_2106604514516997]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [cluster_name]: MAX(SUM([Calculation_2106604513918979]),SUM([Cluster Gene Over (copy)_2106604514267140]))/SUM([Cluster Size by Transcript Gene Id (copy)_2203361574219776])}' />
            </column>
            <column caption='-log(Padj)' datatype='real' name='[Calculation_3489442696458245]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='-Log([padj],10)' />
            </column>
            <column caption='Cluster Gene Under' datatype='integer' name='[Cluster Gene Over (copy)_2106604514267140]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [cluster_name],[member_database],[gene_id]: IF AVG([log2FoldChange]) &lt;= 0 AND MIN([Calculation_3489442696458245]) &gt;= 1.3 THEN 1 ELSE 0 END}' />
            </column>
            <column aggregation='Sum' caption='Cluster Size by DEG' datatype='integer' name='[Cluster Size (copy)_2106604512428034]' role='dimension' type='ordinal'>
              <calculation class='tableau' formula='{FIXED [cluster_name]: SUM([Cluster Size by Transcript Gene Id (copy)_2203361574219776])}' />
            </column>
            <column caption='Cluster Gene DEG' datatype='integer' name='[Cluster Size by Transcript Gene Id (copy)_2203361574219776]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [cluster_name],[member_database],[gene_id]: IF MIN([Calculation_3489442696458245]) &gt;= 1.3 THEN 1 ELSE 0 END}' />
            </column>
