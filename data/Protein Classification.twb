              <calculation class='tableau' formula='{FIXED [protein_accession (candidate_ko.tsv)],[genome_accession (candidate_ko.tsv)],[hmm_accession]:&#10;  SUM([Calculation_5255560976941063]) /&#10;  AVG([protein_length_approx])&#10;}' />
