      <aliases enabled='yes' />
      <column caption='Protein Target Accession' datatype='string' name='[Calculation_0114792141701121]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [protein_accession], [genome_accession]:&#10;  IFNULL(MAX([target_accession (protein_ncbi.tsv)]),&#10;         MAX([target_accession]))&#10;}' />
      </column>
      <column caption='Protein Ref Coordinate' datatype='string' name='[Calculation_1271750258122753]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [protein_hit_id (protein_ncbi.tsv)],[genome_accession (protein_ncbi.tsv)]:&#10;  MAX(LEFT([target_accession (protein_ncbi.tsv)], 3)+&quot;..&quot;+RIGHT([target_accession (protein_ncbi.tsv)], 6))+&quot;: &quot;+&#10;  STR(MIN(MIN([target_start (protein_ncbi.tsv)], [target_end (protein_ncbi.tsv)])))+&quot;-&quot;+&#10;  STR(MAX(MAX([target_start (protein_ncbi.tsv)], [target_end (protein_ncbi.tsv)])))&#10;}' />
      </column>
      <column caption='Pfam Cluster' datatype='boolean' name='[Calculation_1470892157091840]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='CONTAINS([Parent Cluster ID], &quot;_PF&quot;)' />
      </column>
      <column caption='Reference Members' datatype='boolean' name='[Calculation_1470892157698049]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Member Accession],2) == &quot;XP&quot;' />
      </column>
      <column caption='Protein KO Assignment Score to Threshold Ratio' datatype='real' name='[Calculation_1700491354890240]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [protein_accession]: MAX(&#10;  IF [Calculation_3186204581228544] THEN [Dom Score Close to or Above Threshold (copy)_5695833967153159] ELSE NULL END&#10;)}' />
      </column>
      <column caption='Genome has Reference Protein' datatype='boolean' name='[Calculation_1700491355987969]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [genome_accession]:&#10;  SUM(IF [Calculation_5695833919840260] THEN 1 ELSE 0 END) &gt; 0}' />
      </column>
      <column caption='Step Component Number' datatype='string' name='[Calculation_2379506297294848]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR([step])+&quot;-&quot;+STR([step_option])+&quot;-&quot;+STR([step_option_component])' />
      </column>
      <column caption='Is Assigned KO' datatype='boolean' name='[Calculation_3186204581228544]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[Calculation_5695833866838019] == [hmm_accession]' />
      </column>
      <column caption='HMM Matched Len' datatype='integer' name='[Calculation_5695833864994816]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[hmm_end]-[hmm_start]+1' />
      </column>
      <column caption='Protein Match Len' datatype='integer' name='[Calculation_5695833866121217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[protein_end]-[protein_start]+1' />
      </column>
      <column caption='Protein Assigned KO ID' datatype='string' name='[Calculation_5695833866838019]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [protein_accession]: MAX(&#10;&#10;IF [hmm_db] == &quot;m00009_ko&quot; AND &#10;   [dom_rank_for_protein] == 1 AND&#10;   (([Calculation_5695833919840260] == TRUE AND [Dom Score Close to or Above Threshold (copy)_5695833967153159] &gt;= 1) OR &#10;    ([Calculation_5695833919840260] == FALSE AND [Dom Score Close to or Above Threshold (copy)_5695833967153159] &gt; 0.9))&#10;  THEN [Ortholog ID]&#10;  ELSE NULL&#10;END&#10;&#10;)}' />
      </column>
      <column caption='Reference Protein' datatype='boolean' name='[Calculation_5695833919840260]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([protein_accession],1) != &quot;K&quot; OR ISNULL(INT(RIGHT(LEFT([protein_accession],6),5))) == TRUE' />
      </column>
      <column caption='LogE' datatype='real' name='[Calculation_6305933866291202]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [dom_evalue] == 0 THEN -300 ELSE MAX(LOG([dom_evalue],10),-300) END' />
      </column>
      <column caption='Protein Detected Fragment Len' datatype='integer' name='[Calculation_6305933869731843]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([query_end]-[query_start])+1' />
      </column>
      <column caption='Protein Match Len (Joint Classification)' datatype='integer' name='[Calculation_6305933952000008]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[protein_end (classify.tsv1)]-[protein_start (classify.tsv1)]+1' />
      </column>
      <column datatype='string' name='[Class]' role='dimension' type='nominal' />
      <column datatype='string' name='[Cluster ID]' role='dimension' type='nominal' />
      <column caption='Dom Score to Threshold Ratio' datatype='real' name='[Dom Score Close to or Above Threshold (copy)_5695833967153159]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[dom_score]/[score_threshold]' />
      </column>
      <column datatype='string' name='[Family]' role='dimension' type='nominal' />
      <column caption='Genome Accession1' datatype='string' name='[Genome Accession]' role='dimension' type='nominal' />
      <column caption='Genome has Detected Protein' datatype='boolean' name='[Genome has Reference Protein (copy)_1700491357245443]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [genome_accession]:&#10;  SUM(IF [Calculation_5695833919840260] THEN 0 ELSE 1 END) &gt; 0}' />
      </column>
      <column datatype='string' name='[Order]' role='dimension' type='nominal' />
      <column datatype='string' name='[Ortholog ID]' role='dimension' type='nominal' />
      <column caption='Protein Reference Fragment Len' datatype='integer' name='[Protein Detected Fragment Len (copy)_6305933869895684]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([query_end (protein_ncbi.tsv)]-[query_start (protein_ncbi.tsv)])+1' />
      </column>
      <column caption='Protein Target Coord' datatype='string' name='[Protein Target Accession (copy)_0114792143593474]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [protein_accession], [genome_accession]: IFNULL(&#10;&#10;  // NCBI reference proteins&#10;  STR(MIN(MIN([target_start (protein_ncbi.tsv)], [target_end (protein_ncbi.tsv)])))+&quot;-&quot;+&#10;  STR(MAX(MAX([target_start (protein_ncbi.tsv)], [target_end (protein_ncbi.tsv)]))),&#10;&#10;  // Detected proteins&#10;  STR(MIN(MIN([target_start], [target_end])))+&quot;-&quot;+&#10;  STR(MAX(MAX([target_start], [target_end])))&#10;&#10;)}' />
      </column>
      <column datatype='string' name='[Species]' role='dimension' type='nominal' />
      <column caption='Sub Step Component Number' datatype='string' name='[Step Number (copy)_2379506297561089]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='STR([sub_step])+&quot;-&quot;+STR([sub_step_option])+&quot;-&quot;+STR([sub_step_option_component])' />
