    <worksheet name='Proteins by HMM Accession'>
      <table>
        <view>
          <datasources>
            <datasource caption='classify.tsv+ (Multiple Connections)' name='federated.1jh4lwz0rc3ep414os8tl1xn23xc' />
          </datasources>
          <datasource-dependencies datasource='federated.1jh4lwz0rc3ep414os8tl1xn23xc'>
            <column caption='Protein Detected Coordinate' datatype='string' name='[Calculation_1271750257229824]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{FIXED [protein_hit_id]:&#10;  MAX(LEFT([target_accession], 3)+&quot;..&quot;+RIGHT([target_accession], 6))+&quot;: &quot;+&#10;  STR(MIN(MIN([target_start], [target_end])))+&quot;-&quot;+&#10;  STR(MAX(MAX([target_start], [target_end])))&#10;}' />
            </column>
            <column caption='Protein Ref Coordinate' datatype='string' name='[Calculation_1271750258122753]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{FIXED [protein_hit_id (protein_ncbi.tsv)]:&#10;  MAX(LEFT([target_accession (protein_ncbi.tsv)], 3)+&quot;..&quot;+RIGHT([target_accession (protein_ncbi.tsv)], 6))+&quot;: &quot;+&#10;  STR(MIN(MIN([target_start (protein_ncbi.tsv)], [target_end (protein_ncbi.tsv)])))+&quot;-&quot;+&#10;  STR(MAX(MAX([target_start (protein_ncbi.tsv)], [target_end (protein_ncbi.tsv)])))&#10;}' />
            </column>
            <column caption='Target Accession (Detected or Ref)' datatype='string' name='[Calculation_1271750258466818]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='IFNULL([target_accession (protein_ncbi.tsv)], [target_accession])' />
