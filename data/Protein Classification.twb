              <calculation class='tableau' formula='{FIXED [protein_hit_id]:&#10;  MAX(LEFT([target_accession], 3)+&quot;..&quot;+RIGHT([target_accession], 6))+&quot;: &quot;+&#10;  STR(MIN(MIN([target_start], [target_end])))+&quot;-&quot;+&#10;  STR(MAX(MAX([target_start], [target_end])))&#10;}' />
