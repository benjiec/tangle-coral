      <column caption='Reference Members' datatype='boolean' name='[Calculation_1470892157698049]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([Member Accession],2) == &quot;XP&quot;' />
      </column>
      <column caption='HMM Matched Len' datatype='integer' name='[Calculation_5695833864994816]' role='measure' type='quantitative'>
