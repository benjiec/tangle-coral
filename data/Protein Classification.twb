  <worksheets>
    <worksheet name='Assignment, Reference vs Detected'>
      <table>
        <view>
          <datasources>
            <datasource caption='classify.tsv+ (Multiple Connections)' name='federated.1jh4lwz0rc3ep414os8tl1xn23xc' />
          </datasources>
          <datasource-dependencies datasource='federated.1jh4lwz0rc3ep414os8tl1xn23xc'>
            <column caption='Protein KO Assignment Score to Threshold Ratio' datatype='real' name='[Calculation_1700491354890240]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='{FIXED [protein_accession]: MAX(&#10;  IF [Calculation_3186204581228544] THEN [Dom Score Close to or Above Threshold (copy)_5695833967153159] ELSE NULL END&#10;)}' />
            </column>
            <column caption='Genome has Reference Protein' datatype='boolean' name='[Calculation_1700491355987969]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{FIXED [genome_accession]:&#10;  SUM(IF [Calculation_5695833919840260] THEN 1 ELSE 0 END) &gt; 0}' />
            </column>
            <column caption='Is Assigned KO' datatype='boolean' name='[Calculation_3186204581228544]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='[Calculation_5695833866838019] == [hmm_accession]' />
            </column>
            <column caption='Protein Assigned KO ID' datatype='string' name='[Calculation_5695833866838019]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{FIXED [protein_accession]: MAX(&#10;&#10;IF [hmm_db] == &quot;m00009_ko&quot; AND &#10;   [dom_rank_for_protein] == 1 AND&#10;   (([Calculation_5695833919840260] == TRUE AND [Dom Score Close to or Above Threshold (copy)_5695833967153159] &gt;= 1) OR &#10;    ([Calculation_5695833919840260] == FALSE AND [Dom Score Close to or Above Threshold (copy)_5695833967153159] &gt; 0.9))&#10;  THEN [Ortholog ID]&#10;  ELSE NULL&#10;END&#10;&#10;)}' />
            </column>
            <column caption='Reference Protein' datatype='boolean' name='[Calculation_5695833919840260]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='LEFT([protein_accession],1) != &quot;K&quot; OR ISNULL(INT(RIGHT(LEFT([protein_accession],6),5))) == TRUE' />
            </column>
            <column datatype='string' name='[Class]' role='dimension' type='nominal' />
            <column caption='Dom Score to Threshold Ratio' datatype='real' name='[Dom Score Close to or Above Threshold (copy)_5695833967153159]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[dom_score]/[score_threshold]' />
            </column>
            <column datatype='string' name='[Family]' role='dimension' type='nominal' />
            <column datatype='string' name='[Genome Name]' role='dimension' type='nominal' />
            <column caption='Genome has Detected Protein' datatype='boolean' name='[Genome has Reference Protein (copy)_1700491357245443]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{FIXED [genome_accession]:&#10;  SUM(IF [Calculation_5695833919840260] THEN 0 ELSE 1 END) &gt; 0}' />
            </column>
            <column datatype='string' name='[Genus]' role='dimension' type='nominal' />
