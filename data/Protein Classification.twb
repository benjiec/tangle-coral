      <aliases enabled='yes' />
      <column caption='Distances to Assignment Cutoff' datatype='real' name='[Calculation_0582637179285504]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [proteome_type] == &quot;ncbi-reference&quot; THEN &#10;  [Calculation_5255560976416774] / 1.0&#10;ELSE&#10;  [Calculation_5255560976416774] / 0.9&#10;END' />
      </column>
      <column caption='KO Match Frac of Protein' datatype='real' name='[Calculation_0656235764039680]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [protein_accession (candidate_ko.tsv)],[genome_accession (candidate_ko.tsv)],[hmm_accession]:&#10;  SUM([Calculation_5255560976941063]) /&#10;  AVG([protein_length_approx])&#10;}' />
      </column>
      <column caption='Assigned KO' datatype='string' name='[Calculation_5255560969330689]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [protein_accession (candidate_ko.tsv)], [genome_accession (candidate_ko.tsv)]: MAX(&#10;  IF [assignment_status] == &quot;assigned&quot; THEN [hmm_accession] ELSE NULL END&#10;)}' />
      </column>
      <column caption='KO HMM Matched Len' datatype='integer' name='[Calculation_5255560969711618]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[hmm_end]-[hmm_start]+1' />
      </column>
      <column caption='Fragment Length' datatype='integer' name='[Calculation_5255560970256387]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='ABS([target_end]-[target_start])+1' />
      </column>
      <column caption='Pfam Protein Matched Len' datatype='integer' name='[Calculation_5255560972365828]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[protein_end (candidate_pfam.tsv)]-[protein_start (candidate_pfam.tsv)]+1' />
      </column>
      <column caption='KO LogE' datatype='real' name='[Calculation_5255560973651973]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [dom_evalue] == 0 THEN -300 ELSE MAX(LOG([dom_evalue],10),-300) END' />
      </column>
      <column caption='Score to Threshold Ratio' datatype='real' name='[Calculation_5255560976416774]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[dom_score]/[score_threshold]' />
      </column>
      <column caption='KO Protein Matched Len' datatype='integer' name='[Calculation_5255560976941063]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[protein_end]-[protein_start]+1' />
      </column>
      <column caption='Pfam LogE' datatype='real' name='[Calculation_5255560977977352]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [dom_evalue (candidate_pfam.tsv)] == 0 THEN -300 ELSE MAX(LOG([dom_evalue (candidate_pfam.tsv)],10),-300) END' />
      </column>
      <column caption='Query Matched Len' datatype='integer' name='[Calculation_5255560978567177]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[query_end]-[query_start]+1' />
      </column>
      <column caption='Match for Assigned KO' datatype='boolean' name='[Calculation_5255560980721674]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='[hmm_accession] == [Calculation_5255560969330689]' />
      </column>
      <column caption='Best Scoring Ratio by HMM Accession' datatype='real' name='[Calculation_6106239692582912]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [protein_accession (candidate_ko.tsv)], [genome_accession (candidate_ko.tsv)],[hmm_accession]: MAX([Calculation_5255560976416774])}' />
      </column>
      <column caption='Genome has both proteomes' datatype='boolean' name='[Calculation_6687056795226112]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [genome_accession]: COUNTD([proteome_type]) == 2}' />
      </column>
