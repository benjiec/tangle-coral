            <column caption='Protein Match Len' datatype='integer' name='[Calculation_5695833866121217]' role='measure' type='quantitative'>
              <calculation class='tableau' formula='[protein_end]-[protein_start]+1' />
            </column>
            <column caption='Protein Assigned KO' datatype='string' name='[Calculation_5695833866838019]' role='dimension' type='nominal'>
              <calculation class='tableau' formula='{FIXED [protein_accession]: MAX(IF [hmm_db] == &quot;m00009_ko&quot; AND [dom_rank_for_protein] == 1 AND [Dom Score Close to or Above Threshold (copy)_5695833967153159] &gt; 0.75 THEN [Ortholog ID] ELSE NULL END)}' />
            </column>
            <column caption='Reference Genome' datatype='boolean' name='[Calculation_5695833919840260]' role='dimension' type='nominal'>
