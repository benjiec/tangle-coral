      <column caption='Assigned KO' datatype='string' name='[Calculation_5255560969330689]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='{FIXED [protein_accession (candidate_ko.tsv)]: MAX(&#10;  IF [assignment_status] == &quot;assigned&quot; THEN [hmm_accession] ELSE NULL END&#10;)}' />
