      <column caption='KO LogE' datatype='real' name='[Calculation_5255560973651973]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='IF [dom_evalue] == 0 THEN -300 ELSE MAX(LOG([dom_evalue],10),-300) END' />
