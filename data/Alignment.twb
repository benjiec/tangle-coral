      <aliases enabled='yes' />
      <column caption='Log(KO Evalue)' datatype='real' name='[Calculation_2095150570774528]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='LOG(MAX([ko_evalue],1E-300),10)' />
      </column>
      <column caption='Log(Pfam Evalue)' datatype='integer' name='[Calculation_2095150570889217]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='INT(LOG(MAX([pfam_evalue],1E-300),10))' />
      </column>
      <column caption='Aa Count' datatype='integer' name='[Calculation_2095150571995138]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{INCLUDE [aa]: COUNT([aa])}' />
      </column>
      <column caption='Total Proteins in Cluster' datatype='integer' name='[Calculation_2095150573932551]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='{FIXED [cluster_id]: COUNTD([protein_accession])}' />
      </column>
      <column caption='Highest Occurred AA Frequency' datatype='real' name='[Calculation_2095150574411785]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='MAX([Calculation_2095150571995138])/MAX([Calculation_2095150573932551])' />
      </column>
      <column caption='Is Reference Protein' datatype='boolean' name='[Calculation_2095150580711434]' role='dimension' type='nominal'>
        <calculation class='tableau' formula='LEFT([protein_accession],1) != &apos;K&apos; OR ISNULL(INT(RIGHT(LEFT([protein_accession],6),5))) == TRUE' />
      </column>
      <column caption='Genome Accession1' datatype='string' name='[Genome Accession]' role='dimension' type='nominal' />
