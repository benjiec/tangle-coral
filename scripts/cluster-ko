#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 1 ]]; then
  echo "Usage: $0 <module_id>" >&2
  exit 1
fi

module_id="$(printf "%s" "$1" | tr '[:upper:]' '[:lower:]')"
dir="data/${module_id}_results/faa"
cluster_tsv="data/${module_id}_results/cluster.tsv"

rm -f "$cluster_tsv"
rm -f $dir/K*_*.faa

if [[ ! -d "$dir" ]]; then
  echo "Directory not found: $dir" >&2
  exit 1
fi

found=0
for faa_path in "$dir"/*.faa; do
  [ -e "$faa_path" ] || continue
  found=1
  echo "clustering $faa_path"
  PYTHONPATH=. python3 scripts/cluster-faa.py "$faa_path" "$cluster_tsv"
done

if [[ $found -eq 0 ]]; then
  echo "No .faa files found in $dir" >&2
  exit 1
fi
