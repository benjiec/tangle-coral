#!/bin/bash

# arguments, in order:
#   - module ID (i.e. mNNN)
#   - ko ID (i.e. Kxxx)

mkdir -p data/$1_results/alignments
python3 scripts/fasta-re.py data/$1_results/faa/$2.faa "*" --repl Z > data/$1_results/faa/$2.tmp-noStar.faa.$$
docker run --rm -v /Users/benjie/git/needle/data:/data pegi3s/muscle -in /data/$1_results/faa/$2.tmp-noStar.faa.$$ -out /data/$1_results/alignments/$2-muscle-noStar.faa.$$
python3 scripts/fasta-re.py data/$1_results/alignments/$2-muscle-noStar.faa.$$ Z --repl "*" > data/$1_results/alignments/$2-muscle.faa
rm data/$1_results/faa/$2.tmp-noStar.faa.$$
rm data/$1_results/alignments/$2-muscle-noStar.faa.$$
