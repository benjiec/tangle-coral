#!/bin/bash

# argument: module id, genome accession list file name

module=$1

# Loop through each line of the file
while IFS= read -r acc; do

ko_matches="data/${module}_results/candidate_ko.tsv"
pf_matches="data/${module}_results/candidate_pfam.tsv"

PYTHONPATH=. python3 scripts/classify/classify.py --cpu 2 --filter-by ${ko_matches} --genome-accession $acc pfam-downloads/Pfam-A.hmm ${module} ${pf_matches}

done < $2
