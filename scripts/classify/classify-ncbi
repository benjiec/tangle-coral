#!/bin/bash

# argument: module id, genome accession list file name

module=$1

# Loop through each line of the file
while IFS= read -r acc; do

PYTHONPATH=. python3 scripts/classify/classify.py --cpu 4                         --disable-cutoff-ga --genome-accession $acc data/${module}_ko.hmm ${module}
PYTHONPATH=. python3 scripts/classify/classify.py --cpu 4 --filter-by-prev-output --disable-cutoff-ga --genome-accession $acc kegg-downloads/ko.hmm ${module}
PYTHONPATH=. python3 scripts/classify/classify.py --cpu 4 --filter-by-prev-output --genome-accession $acc pfam-downloads/Pfam-A.hmm ${module}

done < $2
