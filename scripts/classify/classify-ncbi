#!/bin/bash

# argument: genome accession list file name

# Loop through each line of the file
while IFS= read -r acc; do

PYTHONPATH=. python3 scripts/classify/classify.py --cpu 4                         --disable-cutoff-ga --genome-accession $acc data/m00009_ko.hmm m00009
PYTHONPATH=. python3 scripts/classify/classify.py --cpu 4 --filter-by-prev-output --disable-cutoff-ga --genome-accession $acc kegg-downloads/ko.hmm m00009
PYTHONPATH=. python3 scripts/classify/classify.py --cpu 4 --filter-by-prev-output --genome-accession $acc pfam-downloads/Pfam-A.hmm m00009

done < $1
